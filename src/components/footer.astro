---
import { Icon } from "astro-icon/components";
---

<footer class="flex items-center justify-between text-xs text-gray-500">
  <div class="flex items-center gap-4">
    <p>Copyright © 2026 OpenPolicy</p>
    <a
      href="/privacy"
      class="text-gray-500 hover:text-gray-700 transition-colors"
      >Privacy</a
    >
  </div>
  <div class="flex items-center gap-4">
    <a
      href="https://github.com/jamiedavenport"
      target="_blank"
      aria-label="GitHub"
      class="text-gray-400 hover:text-gray-700 transition-colors"
    >
      <Icon name="simple-icons:github" class="w-4 h-4" />
    </a>
    <a
      href="https://x.com/jamiedavenport"
      target="_blank"
      aria-label="X"
      class="text-gray-400 hover:text-gray-700 transition-colors"
    >
      <Icon name="simple-icons:x" class="w-4 h-4" />
    </a>
    <a
      href="https://bsky.app/profile/jamiedavenport.bsky.social"
      target="_blank"
      aria-label="Bluesky"
      class="text-gray-400 hover:text-gray-700 transition-colors"
    >
      <Icon name="simple-icons:bluesky" class="w-4 h-4" />
    </a>
  </div>
</footer>
